# Copy this to .env and adjust paths for your system
# Windows Docker Desktop — use forward slashes (D:/3D STLs, not D:\3D STLs)

# Host paths for your model library drives.
# Each is mounted into the container at /library1 and /library2 respectively.
# Add as many drives as you need by extending docker-compose.yml with additional
# volume mounts and adding the container paths to STL_ROOTS below.
STL_DRIVE_1=F:/3DModelLibrary
STL_DRIVE_2=

# Comma-separated list of container paths to auto-seed as scan roots on
# first boot. Must match the volume mounts in docker-compose.yml.
STL_ROOTS=/mnt/drive1,/mnt/drive2

# Host path where you drop zips/folders to import. Mounted at /import.
IMPORT_DIR=F:/Downloads/STL-Imports

# MyMiniFactory API key — register an app at https://www.myminifactory.com/settings/developer
# Optional: without it the MMF adapter falls back to scraping product pages.
MMF_API_KEY=

# Initial backend log verbosity: DEBUG, INFO (default), WARNING, ERROR, CRITICAL.
# Can also be changed live in the UI (Settings → Preferences → Logging), which
# overrides this and persists across restarts.
LOG_LEVEL=INFO

# NOT an API key itself — this is the encryption key that protects the API
# keys/credentials you enter in Settings (AI provider, Cults3D, MyMiniFactory).
# Those are stored as ciphertext, kept deliberately separate from the key that
# unlocks them, so a leaked database file alone doesn't expose them.
# Recommended: set this to a stable value so those secrets survive a restart.
# If unset, an ephemeral key is generated in memory for the process's lifetime
# only — secrets are NEVER written to a file — so anything encrypted will need
# to be re-entered after every restart. Generate one with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STL_SECRET_KEY=
