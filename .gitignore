.env
data/
# data/ above is the runtime DB volume; the painting module's bundled data
# (canonical paint-line metadata) must ship with the app.
!backend/app/painting/data/
frontend/node_modules/
frontend/dist/
frontend/coverage/
desktop/coverage/
node_modules/
__pycache__/
*.pyc
.DS_Store
.claude/
# Generated GitHub Wiki output (built by scripts/wiki/build_wiki.py)
_wiki_build/
AGENTS.md

# Reorganize/import undo logs (written next to the DB; test artifacts)
reorg_undo_*.log
backend/reorg_undo_*.log
bulk_import_report.csv
corpus_validation_report.csv

# Auto-generated Fernet key for encrypting secrets at rest (app/services/secrets.py).
# Falls back to cwd when DATABASE_URL isn't a resolvable sqlite file path (e.g.
# running pytest/uvicorn from backend/), so it can appear outside data/ too.
.secret_key
backend/.secret_key
