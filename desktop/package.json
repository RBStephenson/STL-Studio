{
  "name": "stl-studio-desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Electron desktop shell for STL Studio (replaces the pywebview standalone build).",
  "author": "STL Studio",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win --publish never",
    "test": "vitest run",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
